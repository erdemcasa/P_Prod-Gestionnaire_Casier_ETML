<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Login</title>
  @vite(['resources/css/app.css'])
</head>
<body>
  <div class="box">
    <h2>Connexion</h2>

    @if(flashMessages.has('error'))
      <p style="color:red">{{ flashMessages.get('error') }}</p>
    @endif

    <form method="POST" action="{{ route('auth.login.store') }}">
      {{ csrfField() }}

      <input
        type="text"
        name="eduvaudId"
        placeholder="Eduvaud ID"
        value="{{ old('eduvaudId') || '' }}"
        required
      />

      <input
        type="password"
        name="password"
        placeholder="Mot de passe"
        required
      />

      <button type="submit">Connexion</button>
    </form>
  </div>
</body>
</html>
